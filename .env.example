# =============================================================================
# Store identity (defaults; overridden by store_settings row in DB once
# you edit them in the admin UI)
# =============================================================================
STORE_NAME="Iron Forge"
STORE_TAGLINE="Fuel your strongest self"
STORE_DESCRIPTION="Premium supplements, performance apparel, and gym essentials."
STORE_DEFAULT_LOCALE="en"
STORE_DEFAULT_CURRENCY="PKR"
STORE_SUPPORT_EMAIL="support@example.com"
STORE_LOGO_URL="/logo.svg"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # server-only, NEVER expose

# =============================================================================
# Stripe (international cards)
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# =============================================================================
# Pakistan payment providers
# =============================================================================
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
JAZZCASH_RETURN_URL=""

EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""
EASYPAISA_RETURN_URL=""

# =============================================================================
# Misc
# =============================================================================
ENCRYPTION_KEY=""
RESEND_API_KEY=""
EMAIL_FROM="no-reply@example.com"

NODE_ENV="development"
LOG_LEVEL="info"
